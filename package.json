{
  "name": "webgpu-renderer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://vgc12.github.io/webgpu-renderer/",
  "scripts": {
    "deploy": "gh-pages -d dist",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "linux-dev": "vite & sleep 1 && brave --ozone-platform=x11 http://localhost:5173",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:dev": "vitepress dev docs",
    "docs:linux-dev": "vitepress dev docs & sleep 1 && brave --ozone-platform=x11 http://localhost:5173",
    "docs:build": "vitepress build docs",
    "build:all": "npm run build && npm run docs:build && cp -r docs/.vitepress/dist dist/docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@mermaid-js/mermaid-mindmap": "^9.3.0",
    "@types/lz-string": "^1.3.34",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "@vitejs/plugin-react": "^4.5.2",
    "@webgpu/types": "^0.1.61",
    "eslint": "^9.28.0",
    "gh-pages": "^6.3.0",
    "mermaid": "^9.1.7",
    "tw-animate-css": "^1.3.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.34.0",
    "vite": "^6.3.5",
    "vite-plugin-string": "^1.2.3",
    "vitepress-plugin-mermaid": "^2.0.10",
